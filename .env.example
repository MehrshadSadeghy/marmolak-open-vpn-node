# Copy to .env before docker compose up
API_PORT=8090
NODE_API_SECRET=change-me-node-secret
MOCK_MODE=true
SERVER_HOST=vpn.example.com
SERVER_PORT=1194
SERVER_PROTO=udp

# Optional: writable env file on host for automatic port/proto updates from the bot
# OPENVPN_DOTENV_PATHS=/etc/openvpn/open-node.env
# Mount in docker-compose: ./.env:/etc/openvpn/open-node.env
# If PKI lives elsewhere on the host:
# OPENVPN_PKI_HOST_PATH=/path/to/pki
